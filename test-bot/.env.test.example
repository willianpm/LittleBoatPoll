# =====================================
# CONFIGURAÇÃO DE TESTES AUTOMATIZADOS
# =====================================
# Copie este arquivo para .env.test e configure

# Token do bot de teste (crie um bot separado no Discord Developer Portal)
TEST_BOT_TOKEN=your_test_bot_token_here

# ID do bot staging que será testado
STAGING_BOT_ID=your_staging_bot_id_here

# ID do canal onde os testes serão executados
TEST_CHANNEL_ID=your_test_channel_id_here

# ID do servidor (guild) de testes
TEST_GUILD_ID=your_test_guild_id_here
