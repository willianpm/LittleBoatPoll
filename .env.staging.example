# ═══════════════════════════════════════════════════════
# BOT DE STAGING (HOMOLOGAÇÃO)
# ═══════════════════════════════════════════════════════
# Este é um arquivo de exemplo. Copie como .env.staging e preencha com
# as credenciais do bot secundário criado no Discord Developer Portal.

APP_ENV=staging
INSTANCE_ID=staging-local

# ═══════════════════════════════════════════════════════
# CREDENCIAIS DO BOT STAGING
# ═══════════════════════════════════════════════════════
# ⚠️ IMPORTANTE: Use credenciais DIFERENTES do bot de produção
# Crie uma segunda aplicação no Discord Developer Portal para staging

# Token do bot staging (DIFERENTE do token de produção)
TOKEN=seu_token_staging_aqui

# Client ID do bot staging (DIFERENTE do client ID de produção)
CLIENT_ID=seu_client_id_staging_aqui

# Client Secret da aplicação staging
CLIENT_SECRET=seu_client_secret_staging_aqui

# ═══════════════════════════════════════════════════════
# DASHBOARD WEB (OAUTH DISCORD - STAGING LOCAL)
# ═══════════════════════════════════════════════════════

# Opcional: por padrão, o dashboard usa CLIENT_ID acima
# DISCORD_CLIENT_ID=seu_client_id_staging_aqui

# Obrigatório para OAuth web do dashboard
DISCORD_CLIENT_SECRET=seu_client_secret_staging_aqui

# Callback OAuth registrado no Discord Developer Portal para staging
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8001/api/auth/discord/callback

# URL base usada no redirecionamento pós-login
DASHBOARD_FRONTEND_URL=http://localhost:8001

# Secret da sessão HTTP do dashboard
DASHBOARD_SESSION_SECRET=troque_este_secret_staging

# Opcional: restringe dashboard a uma guild específica
# DASHBOARD_ALLOWED_GUILD_ID=seu_guild_id_staging_aqui

# ═══════════════════════════════════════════════════════
# CONFIGURAÇÕES DE STAGING
# ═══════════════════════════════════════════════════════

# Deploy automático na primeira execução
DEPLOY=true

# Debug ativado para staging (logs detalhados)
DEBUG=true

# Porta diferente para evitar conflito se rodar ambos simultaneamente
PORT=8001

# ═══════════════════════════════════════════════════════
# COMO USAR
# ═══════════════════════════════════════════════════════
# 
# 1. Crie um segundo bot no Discord Developer Portal
# 2. Copie este arquivo como .env.staging
# 3. Preencha TOKEN e CLIENT_ID com as credenciais do bot staging
# 4. Execute com: APP_ENV=staging npm start
#
# Guia completo: docs/staging-bot.md
