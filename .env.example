# ⚙️ Configuração das Variáveis de Ambiente

## Copie este arquivo para .env e preencha com seus valores

# ═══════════════════════════════════════════════════════
# AMBIENTE (prod|staging)
# ═══════════════════════════════════════════════════════
# Define o ambiente de execução
# - prod: Produção (padrão) - dados em data/environments/prod/
# - staging: Homologação - dados em data/environments/staging/
APP_ENV=prod

# Identificador único da instância (opcional - gerado automaticamente)
# INSTANCE_ID=prod-1

# ═══════════════════════════════════════════════════════
# DISCORD BOT
# ═══════════════════════════════════════════════════════

# Token do Bot Discord (OBRIGATÓRIO)
# Encontre em: https://discord.com/developers/applications
# Vá em: Bot → Token → Copy
TOKEN=seu_token_aqui

# ID da Aplicação/Bot (OBRIGATÓRIO)
# Encontre em: https://discord.com/developers/applications
# Vá em: General Information → Application ID
CLIENT_ID=seu_client_id_aqui

# Client Secret da aplicação Discord (necessário para login OAuth do dashboard)
# Encontre em: OAuth2 → Client Secret
CLIENT_SECRET=seu_client_secret_aqui

# ID do Servidor Discord (OPCIONAL)
# Para comandos específicos de servidor
# Habilite Developer Mode no Discord e copie Server ID
GUILD_ID=seu_guild_id_aqui

# ═══════════════════════════════════════════════════════
# DASHBOARD WEB (OAUTH DISCORD)
# ═══════════════════════════════════════════════════════

# Opcional: por padrão, o dashboard usa CLIENT_ID acima
# DISCORD_CLIENT_ID=seu_client_id_aqui

# Obrigatório para OAuth web do dashboard
DISCORD_CLIENT_SECRET=seu_client_secret_aqui

# Callback OAuth registrado no Discord Developer Portal
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback

# URL base usada no redirecionamento pós-login
DASHBOARD_FRONTEND_URL=http://localhost:8000

# Secret da sessão HTTP do dashboard
DASHBOARD_SESSION_SECRET=troque_este_secret

# Opcional: restringe dashboard a uma guild específica
# DASHBOARD_ALLOWED_GUILD_ID=seu_guild_id_aqui

# ═══════════════════════════════════════════════════════
# DEPLOY E DEBUG
# ═══════════════════════════════════════════════════════

# Deploy automático de comandos na inicialização (true|false)
# DEPLOY=false

# Modo debug - logs detalhados (true|false)
# DEBUG=false

# ═══════════════════════════════════════════════════════
# SERVIDOR HTTP (KEEP-ALIVE)
# ═══════════════════════════════════════════════════════

# Porta do servidor HTTP (opcional - padrão: 8000)
# PORT=8000

# ⚠️ IMPORTANTE:
# - NUNCA compartilhe seu TOKEN
# - NUNCA faça commit do arquivo .env no Git
# - Use .env apenas localmente
# - Para produção, use variáveis de ambiente do servidor
