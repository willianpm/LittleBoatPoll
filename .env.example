# Exemplo de .env para LittleBoatPoll
# Copie para .env e preencha os valores obrigatórios

# Ambiente: prod ou staging
APP_ENV=prod

# Redis
REDIS_PASSWORD=troque_esta_senha
REDIS_URL=redis://:troque_esta_senha@redis:6379

# Discord Bot
TOKEN=seu_token_aqui           # obrigatório
CLIENT_ID=seu_client_id_aqui   # obrigatório
CLIENT_SECRET=seu_client_secret_aqui
GUILD_ID=seu_guild_id_aqui     # opcional

# Dashboard Web (OAuth Discord)
DISCORD_CLIENT_SECRET=seu_client_secret_aqui
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback
DASHBOARD_FRONTEND_URL=http://localhost:8000
DASHBOARD_SESSION_SECRET=troque_este_secret
# DASHBOARD_ALLOWED_GUILD_ID=seu_guild_id_aqui

# Deploy e Debug
# DEPLOY=false
# DEBUG=false

# Servidor HTTP
# PORT=8000

# ⚠️ Nunca compartilhe seu TOKEN ou faça commit do .env
