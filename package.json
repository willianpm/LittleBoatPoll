{
  "name": "littleboatpoll",
  "version": "2.1.0",
  "description": "Discord bot for managing book club polls with weighted voting (monthly members get weight 2)",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/willianpm/LittleBoatPoll.git"
  },
  "homepage": "https://github.com/willianpm/LittleBoatPoll#readme",
  "bugs": {
    "url": "https://github.com/willianpm/LittleBoatPoll/issues"
  },
  "scripts": {
    "start": "node index.js",
    "start:quick": "node index.js",
    "start:staging": "npx cross-env APP_ENV=staging node index.js",
    "deploy": "node index.js --deploy",
    "deploy:staging": "npx cross-env APP_ENV=staging node index.js --deploy",
    "dev": "node index.js",
    "migrate:data": "node scripts/migrate-data.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:automation": "node test-bot/test-runner.js",
    "test:full": "node test-bot/run-full-tests.js"
  },
  "keywords": [
    "discord",
    "bot",
    "voting",
    "polls",
    "book-club",
    "slash-commands",
    "context-menus",
    "discord.js"
  ],
  "author": "Willian Martins",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  }
}
