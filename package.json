{
  "name": "littleboatpoll",
  "version": "2.1.0",
  "description": "Discord bot for managing book club polls with weighted voting (monthly members get weight 2)",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/willianpm/LittleBoatPoll.git"
  },
  "homepage": "https://github.com/willianpm/LittleBoatPoll#readme",
  "bugs": {
    "url": "https://github.com/willianpm/LittleBoatPoll/issues"
  },
  "scripts": {
    "start": "node src/core/index.js",
    "start:quick": "node src/core/index.js",
    "start:staging": "cross-env APP_ENV=staging node src/core/index.js",
    "dev": "node src/core/index.js",
    "deploy": "node src/core/index.js --deploy",
    "deploy:staging": "cross-env APP_ENV=staging node src/core/index.js --deploy",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --passWithNoTests",
    "test:automation": "node test-bot/test-runner.js",
    "test:full": "node test-bot/run-full-tests.js",
    "lint": "eslint src/ tests/ --max-warnings=0",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "discord",
    "bot",
    "voting",
    "polls",
    "book-club",
    "slash-commands",
    "context-menus",
    "discord.js"
  ],
  "author": "Willian Martins",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "jest": "^30.2.0",
    "prettier": "^3.1.0"
  }
}
